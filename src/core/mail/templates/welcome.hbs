<!DOCTYPE html>
<html>
<body style="margin:0;padding:0;background:#f4f4f4;font-family:Arial,sans-serif;">
  <table width="560" style="margin:40px auto;background:#fff;border-radius:12px;overflow:hidden;">
    <tr>
      <td style="background:#1a1a2e;padding:32px;text-align:center;">
        <p style="color:#fff;font-size:20px;font-weight:600;margin:0;">Quant Reader</p>
      </td>
    </tr>
    <tr>
